# Copy this file to .env.local and fill in the values.
#   cp .env.example .env.local
#
# NEXT_PUBLIC_* variables are exposed to the browser. Everything else is
# server-only and must NOT be prefixed with NEXT_PUBLIC_.

# --- Supabase ---------------------------------------------------------------
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Secret service-role key (server-side only). Bypasses RLS — never expose this.
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe -----------------------------------------------------------------
# From the Stripe dashboard: Developers -> API keys
STRIPE_SECRET_KEY=
# Signing secret for the /api/stripe/webhook endpoint
# (Stripe dashboard: Developers -> Webhooks -> your endpoint)
STRIPE_WEBHOOK_SECRET=

# --- App URLs ---------------------------------------------------------------
# Public base URLs used for redirects, OAuth callbacks, and Stripe return URLs.
# Local dev: http://localhost:3000   Production: your deployed site URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000
